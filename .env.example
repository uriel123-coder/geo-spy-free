# 📝 PLANTILLA DE VARIABLES DE ENTORNO
# Copia este archivo a `.env` y llena las variables necesarias
# IMPORTANTE: `.env` está en .gitignore - NUNCA se sube a GitHub

# ===== CONFIGURACIÓN DE GEMINI (OPCIONAL) =====
# Para usar análisis avanzado con Gemini Vision
# Obtén tu clave en: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=tu_clave_api_aqui

# GOOGLE_API_KEY=tu_otra_clave_aqui

# ===== CONFIGURACIÓN DE SERVIDOR =====
# Puerto en el que correr Flask
FLASK_PORT=5000

# Ambiente (development o production)
FLASK_ENV=development

# ===== CONFIGURACIÓN DE MODELOS =====
# Usar GPU (True) o CPU (False)
USE_GPU=True

# Directorio de caché de modelos
MODELS_CACHE_DIR=./models

# ===== LOGGING =====
LOG_LEVEL=INFO
# Opciones: DEBUG, INFO, WARNING, ERROR, CRITICAL
